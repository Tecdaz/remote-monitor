# Local-testing environment values — template.
#
# Copy this file to backend/.env.test and fill in the real values.
# backend/.env.test is gitignored; this template is the only
# checked-in file in the .env.test family.
#
# See docs/local-testing.md for the full local-testing playbook.

# Symmetric key for pgp_sym_encrypt / pgp_sym_decrypt on
# pii.patients.patient_number (pgcrypto). Required for the backend
# to start. Generate a random 32+ char string for local dev:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# In production this comes from a secret store (Vault, AWS Secrets
# Manager, GCP Secret Manager), never from a checked-in file.
APP_PII_ENCRYPTION_KEY=replace-me-with-a-random-32-char-string

# Optional override. Defaults to the docker-compose postgres
# service. Set this only if you run the backend outside docker
# (e.g. `uv run uvicorn` against a local Postgres on :5432).
# APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/remote_monitor

# Free-tier ngrok authtoken from
# https://dashboard.ngrok.com/get-started/your-authtoken.
# Required for ngrok-based testing on a real device. Without it,
# use a direct LAN IP instead (`-PapiBaseUrl=http://192.168.1.X:8000/`).
NGROK_AUTHTOKEN=replace-me-with-your-ngrok-authtoken

# The current ngrok public URL. Rotates on every ngrok restart.
# Use `-PapiBaseUrl=$NGROK_PUBLIC_URL` when building the watch
# APK so the build picks up the latest value. This file holds
# the *latest known* value so you can grep it after a tunnel
# restart.
NGROK_PUBLIC_URL=https://replace-me-with-your-current-ngrok-url/
