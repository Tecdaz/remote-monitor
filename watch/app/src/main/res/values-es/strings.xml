    <string name="bed_free">Libre</string>
    <string name="bed_occupied">Ocupada</string>
    <string name="dialog_occupied_title">Cama ocupada</string>
    <string name="dialog_occupied_body">Esta cama ya tiene una sesión activa. Si continúas, se asignará una nueva sesión y la sesión actual quedará inactiva.</string>
