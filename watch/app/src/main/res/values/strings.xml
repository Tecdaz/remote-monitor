<resources>
    <string name="app_name">Remote Monitor</string>
    <string name="hello_world">Hello, %1$s!</string>
    <string name="sync_notification_text">Monitoring patient</string>

    <!--
        wear-ui-guidelines D5 + D7 (spec #448 cap 2 + cap 5): localized
        copy for the FGS notification + the Ongoing Activity status text
        paired with it. `sync_notification_text` is the existing key
        (its Spanish translation is added below in `values-es/strings.xml`
        — it was MISSING pre-PR-4, which would have caused the FGS body
        to fall back to English for any paired es-ES watch).

        DEBT-002 (#433 §3.1): these four strings ship with the PR but
        are BLOCKED from GA until the clinical stakeholder signs off on
        the Spanish clinical copy. Do NOT release before
        `clinical_sign_off_completed`.

        Format-arg discipline (D25): `sync_bed_body_format` uses string
        `%1$s` (the bed number as plaintext, e.g. "3"). Tests assert
        via `context.getString(...)`, never a hardcoded literal.
    -->
    <string name="sync_notification_title">Sync</string>
    <string name="sync_status_short">Sync</string>
    <string name="sync_bed_body_format">Bed %1$s · syncing</string>

    <!--
        wear-bed-picker-onboarding D7 + D25 + WB-5: English fallback keys
        for the bed-picker onboarding dialog. The Spanish translations
        live in `values-es/strings.xml`. The `home_*` / `action_repair`
        keys are owned by PR-3c (T3.13) and follow the locked format-arg
        discipline from §11.4 of design-files #425:
          * `home_bed_label`   uses positional `%1$d`.
          * `home_status_label` uses `%1$d` and `%2$d` positionally.
        Tests assert via `context.getString(R.string.home_bed_label, 3)`
        == "Bed 3" — NOT a hardcoded literal.
    -->
    <string name="onboarding_title">Select a bed</string>
    <string name="onboarding_section_label">Select the bed for this device</string>
    <string name="bed_free">Free</string>
    <string name="bed_occupied">Occupied</string>
    <string name="dialog_occupied_title">Bed occupied</string>
    <string name="dialog_occupied_body">This bed already has an active session. If you continue, a new session will be assigned and the current session will become inactive.</string>
    <string name="dialog_accept">Accept</string>
    <string name="dialog_cancel">Cancel</string>
    <string name="snackbar_paired_to_bed">Paired to bed %1$d</string>
    <string name="error_post_failed">Failed to register the bed. Please try again.</string>
    <string name="error_snapshot_failed">Failed to load bed status. Tap Retry.</string>
    <string name="action_retry">Retry</string>
    <string name="home_bed_label">Bed %1$d</string>
    <string name="home_status_label">Bed %1$d · %2$d pending uploads</string>
    <string name="action_repair">Re-pair</string>

    <!--
        wear-ui-guidelines D4 + D6 (spec cap 1): ADDITIVE glanceable HR
        vitals keys for the home screen. The existing `home_status_label`
        shape is UNCHANGED (D25 invariant) — these are new keys only.

        DEBT-002 (#433 §3.1): these four strings ship with the PR but are
        BLOCKED from GA until the clinical stakeholder signs off on the
        Spanish clinical copy (notably the `lpm` = "latidos por minuto"
        unit choice in `home_hr_value_format`). Do NOT release before
        `clinical_sign_off_completed`.

        Format-arg discipline (D25): `home_hr_value_format` uses numeric
        `%1$d`; `home_last_update_label` uses string `%1$s` (a formatted
        HH:mm time). Tests assert via `context.getString(...)`, never a
        hardcoded literal.
    -->
    <string name="home_hr_label">Heart rate</string>
    <string name="home_hr_value_format">%1$d bpm</string>
    <string name="home_last_update_label">Last update %1$s</string>
    <string name="home_hr_placeholder">—</string>

    <!--
        wear-bed-picker-onboarding-warnings WARN-005: dedicated copy for
        RepairRequiredScreen. Previously the screen reused `action_repair`
        as its title and `dialog_occupied_body` as its body, which
        described a tap-confirmation flow on the first-screen re-pair
        prompt — confusing the operator. The button keeps
        `action_repair` because that IS the action label.
    -->
    <string name="repair_required_title">Re-pair required</string>
    <string name="repair_required_body">Your device is paired to an old patient number. Tap Re-pair to assign it to a bed.</string>
</resources>
